# Copy values into `.env.local` (gitignored) for day-to-day dev, or set in CI for `vite build`.
# Load order (last wins): .env → .env.local → .env.[mode] → .env.[mode].local

# -----------------------------------------------------------------------------
# Vite dev server & preview (vite.config.ts)
# -----------------------------------------------------------------------------
VITE_PORT=5582

# -----------------------------------------------------------------------------
# Backend for `/api` proxy + SignalR dev origin — must end with /
# Default: local API on 5581
# -----------------------------------------------------------------------------
VITE_PROXY_TARGET=http://127.0.0.1:5581/

# -----------------------------------------------------------------------------
# Google Sign-In — public web client ID (different per OAuth app / origins)
# -----------------------------------------------------------------------------
# 1) Local: client with Authorized JavaScript origins http://localhost:5582 (and/or http://127.0.0.1:5582)
# VITE_GOOGLE_CLIENT_ID=

# 2) Shared dev (“dev-api” backend + “dev-dash” URL in Google Console): use that OAuth client here
# VITE_PROXY_TARGET=https://YOUR_DEV_API_ORIGIN/
# VITE_GOOGLE_CLIENT_ID=

# 3) Production — copy `.env.production.example` → `.env.production` (gitignored) or set vars in CI; overrides dev `VITE_*` from `.env.local` on `vite build`

# Optional — see src/utils/signalrHubUrl.ts, useSignalRService.ts
# VITE_SIGNALR_ORIGIN=
# VITE_SIGNALR_SKIP_WEBSOCKETS=1
